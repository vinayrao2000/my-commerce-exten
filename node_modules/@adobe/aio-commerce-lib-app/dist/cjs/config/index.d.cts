 * const config = {
 *   businessConfiguration: {
 *     // ... configuration data
 *   }
 * };
 *
 * try {
 *   const validatedConfig = validateCommerceAppConfig(config);
 *   // Use validatedConfig safely
 * } catch (error) {
 *   if (error instanceof CommerceSdkValidationError) {
 *     console.error('Validation failed:', error.display());
 *   }
 * }
 * ```
 */
