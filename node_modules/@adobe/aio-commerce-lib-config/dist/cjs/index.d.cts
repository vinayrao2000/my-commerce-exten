/** Options for controlling operations of the configuration library. */
type OperationOptions = {
  /** Optional cache timeout in seconds. */cacheTimeout?: number;
};
/** Options for controlling configuration operations. */
type ConfigOptions = OperationOptions & {
  /** Optional encryption key for encrypting/decrypting password fields. */encryptionKey?: string;
};
