{
  "name": "@adobe/aio-commerce-lib-config",
  "type": "module",
  "author": "Adobe Inc.",
  "version": "1.5.1",
  "private": false,
  "engines": {
    "node": ">=22 <=24"
  },
  "license": "Apache-2.0",
  "description": "Configuration management utilities for Adobe Commerce apps deployed in Adobe App Builder",
  "keywords": [
    "aio",
    "adobe-io",
    "commerce",
    "adobe-commerce",
    "adobe-commerce-sdk",
    "aio-commerce-sdk",
    "aio-commerce-lib-config",
    "configuration",
    "config-management",
    "app-builder"
  ],
  "bugs": {
    "url": "https://github.com/adobe/aio-commerce-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adobe/aio-commerce-sdk.git",
    "directory": "packages/aio-commerce-lib-config"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.mjs",
  "types": "./dist/cjs/index.d.cts",
  "bin": {
    "aio-commerce-lib-config": "./bin/cli.mjs"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.mts",
        "default": "./dist/es/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "imports": {
    "#*": "./source/*.ts",
    "#test/*": "./test/*.ts"
  },
  "files": [
    "bin",
    "dist",
    "package.json",
    "CHANGELOG.md",
    "README.md"
  ],
  "dependencies": {
    "@adobe/aio-lib-core-config": "^5.0.1",
    "@adobe/aio-lib-core-logging": "^3.0.2",
    "@adobe/aio-lib-files": "^4.1.2",
    "@adobe/aio-lib-ims": "^8.1.1",
    "@adobe/aio-lib-state": "^5.3.1",
    "consola": "^3.4.2",
    "dotenv": "^17.2.3",
    "package-manager-detector": "^1.6.0",
    "safe-stable-stringify": "^2.5.0",
    "type-fest": "^5.0.0",
    "uuid": "^14.0.0",
    "valibot": "^1.1.0",
    "@adobe/aio-commerce-lib-api": "1.2.1",
    "@adobe/aio-commerce-lib-core": "1.1.1"
  },
  "devDependencies": {
    "msw": "^2.11.1",
    "typescript": "^6.0.0",
    "@aio-commerce-sdk/common-utils": "0.2.5",
    "@adobe/aio-commerce-lib-auth": "1.1.1",
    "@aio-commerce-sdk/config-tsdown": "1.0.1",
    "@aio-commerce-sdk/config-typedoc": "1.0.0",
    "@aio-commerce-sdk/config-typescript": "1.0.0",
    "@aio-commerce-sdk/config-vitest": "1.0.0",
    "@aio-commerce-sdk/scripting-utils": "0.3.3",
    "@aio-commerce-sdk/scripts": "0.1.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "pack": "pnpm pack",
    "publint": "publint",
    "docs": "typedoc && prettier --write '**/*.md'",
    "assist": "biome check --formatter-enabled=false --linter-enabled=false --assist-enabled=true --no-errors-on-unmatched",
    "assist:apply": "biome check --write --formatter-enabled=false --linter-enabled=false --assist-enabled=true --no-errors-on-unmatched",
    "check:ci": "biome ci --formatter-enabled=true --linter-enabled=true --assist-enabled=true --no-errors-on-unmatched",
    "code:fix": "pnpm run lint:fix && pnpm run assist:apply && pnpm run format && pnpm run format:markdown",
    "format": "biome format --write --no-errors-on-unmatched",
    "format:markdown": "prettier --no-error-on-unmatched-pattern --write '**/*.md' \"!**/{CODE_OF_CONDUCT.md,COPYRIGHT,LICENSE,SECURITY.md,CONTRIBUTING.md}\"",
    "format:check": "biome format --no-errors-on-unmatched",
    "lint": "biome lint --no-errors-on-unmatched",
    "lint:fix": "biome lint --write --no-errors-on-unmatched",
    "typecheck": "tsc --noEmit && echo '✅ No type errors found.'",
    "test": "vitest run --coverage",
    "test:watch": "vitest --coverage",
    "test:ui": "vitest --ui"
  }
}