/**
 * Represents a Bearer authentication scheme (RFC 6750).
 */
type BearerAuthorization = {
  scheme: "Bearer";
  token: string;
};
/**
 * Represents a Basic authentication scheme (RFC 7617).
 */
type BasicAuthorization = {
  scheme: "Basic";
  credentials: string;
};
/**
 * OAuth 1.0 parameters as defined in RFC 5849.
 */
